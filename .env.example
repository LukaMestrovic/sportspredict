# SportPredict Probability Cup API key (prefix sp_live_)
SPORTSPREDICT_KEY=sp_live_xxx
# API-Football v3 key (api-sports.io direct host)
APIFOOTBALL_KEY=xxx
# The Odds API key (the-odds-api.com) — PAID/metered; responses are cached
ODDS_API_KEY=xxx
# OpenAI API key (parser fallback, compound splitter, LLM pricing)
OPENAI_API_KEY=sk-xxx
# Optional: override the cached parser model (default gpt-5.4-mini)
# PARSER_MODEL=gpt-5.4-mini
# Optional: override LLM pricing model (default gpt-5.5)
# LLM_PRICING_MODEL=gpt-5.5
# Optional: override API fallback reasoning effort (default high)
# LLM_PRICING_REASONING_EFFORT=high
# Optional: disable LLM pricing for deterministic local validation.
# LLM_PRICING_ENABLED=0
# Optional: override bundled simulator draws per match (default 8000, max 10000).
# SPORTSPREDICT_SIMULATOR_N_SIMS=8000
