# SportPredict Probability Cup API key (prefix sp_live_)
SPORTSPREDICT_KEY=sp_live_xxx
# API-Football v3 key (api-sports.io direct host)
APIFOOTBALL_KEY=xxx
# The Odds API key (the-odds-api.com) — PAID/metered; responses are cached
ODDS_API_KEY=xxx
# OpenAI API key (LLM parser, compound splitter, external web estimate)
OPENAI_API_KEY=sk-xxx
# Optional: disable the paid web-search fallback layer
# EXTERNAL_FALLBACK=0
