# SportPredict Probability Cup API key (prefix sp_live_)
SPORTSPREDICT_KEY=sp_live_xxx
# API-Football v3 key (api-sports.io direct host)
APIFOOTBALL_KEY=xxx
# The Odds API key (the-odds-api.com) — quota-metered; free plans are supported
ODDS_API_KEY=xxx
# Optional: comma-separated Odds API regions (default is defined in bot config).
# ODDS_REGIONS=eu
# Optional: override bundled simulator draws per match (default 8000, max 10000).
# SPORTSPREDICT_SIMULATOR_N_SIMS=8000
