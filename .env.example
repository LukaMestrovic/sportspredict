# SportPredict Probability Cup API key (prefix sp_live_)
SPORTSPREDICT_KEY=sp_live_xxx
# API-Football v3 key (api-sports.io direct host)
APIFOOTBALL_KEY=xxx
# The Odds API key (the-odds-api.com) — PAID/metered; responses are cached
ODDS_API_KEY=xxx
# OpenAI API key (parser fallback, compound splitter, final LLM pricing)
OPENAI_API_KEY=sk-xxx
# Optional: override the cached parser model (default gpt-4.1)
# PARSER_MODEL=gpt-4.1
# Optional: override final LLM pricing model (default gpt-5.5)
# LLM_PRICING_MODEL=gpt-5.5
# Optional: disable final LLM pricing for deterministic local validation.
# LLM_PRICING_ENABLED=0
